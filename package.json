{
  "name": "amazon-erp",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "node scripts/check-supabase-env.mjs && vite",
    "build": "node scripts/check-supabase-env.mjs && vue-tsc -b && vite build",
    "preview": "node scripts/check-supabase-env.mjs && vite preview",
    "env:init": "node scripts/check-supabase-env.mjs",
    "verify:docs": "node scripts/verify-agent-docs.mjs",
    "verify:risk": "node scripts/scan-risk-files.mjs",
    "review:local": "node scripts/review-local.mjs",
    "verify:agent": "npm run build && npm run verify:docs && npm run verify:risk && npm run review:local",
    "prepare": "simple-git-hooks"
  },
  "dependencies": {
    "@ant-design/icons-vue": "^7.0.1",
    "@supabase/supabase-js": "^2.57.4",
    "ant-design-vue": "^4.2.6",
    "dayjs": "^1.11.13",
    "vue": "^3.4.38",
    "vue-router": "^4.4.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.1.3",
    "less": "^4.2.0",
    "simple-git-hooks": "^2.13.1",
    "typescript": "^5.5.3",
    "vite": "^5.4.2",
    "vue-tsc": "^2.1.4"
  },
  "simple-git-hooks": {
    "pre-commit": "npm run verify:docs",
    "pre-push": "npm run verify:agent"
  }
}
