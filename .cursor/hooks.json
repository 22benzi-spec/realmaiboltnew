{
  "version": 1,
  "hooks": {
    "beforeShellExecution": [
      {
        "command": "node .cursor/hooks/guard-risky-shell.mjs",
        "matcher": "git\\s+reset\\s+--hard|git\\s+checkout\\s+--|git\\s+push\\s+--force|rm\\s+-rf|Remove-Item\\s+.*-Recurse\\s+.*-Force",
        "failClosed": true,
        "timeout": 10
      }
    ]
  }
}
